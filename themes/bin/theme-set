#!/usr/bin/env bash
#
# theme-set - Switch the active color palette and apply it
#
set -euo pipefail

THEMES_DIR="$(cd "$(dirname "$0")/.." && pwd)"
PALETTES_DIR="$THEMES_DIR/palettes"
COLORS_FILE="$THEMES_DIR/colors.toml"
APPS_DIR="$THEMES_DIR/apps"
THEME_APPLY="$THEMES_DIR/bin/theme-apply"

# Neovim colorscheme plugin location
NVIM_COLORSCHEME="$HOME/.config/nvim/lua/plugins/colorscheme.lua"


usage() {
    cat <<'EOF'
Usage: theme-set [options] [<palette>]

Switch the active color palette and apply it to all configured apps.

With no arguments, lists available palettes.

Options:
  --neovim <palette>    Only update the neovim colorscheme for a palette
  -h, --help            Show this help message

Examples:
  theme-set                       List available palettes
  theme-set catppuccin-mocha      Activate the catppuccin-mocha palette
  theme-set tokyo-night           Activate the tokyo-night palette
  theme-set --neovim ayu          Update only the neovim colorscheme for ayu

What it does:
  1. Copies palettes/<name>.toml to colors.toml
  2. Runs theme-apply to render all templates
  3. Copies neovim metadata from apps/<name>/ if present
  4. Sends reload signals to ghostty, waybar, and mako
  5. Updates wallpaper if the palette defines one
EOF
}

neovim_guide() {
    local palette="$1"
    cat <<EOF
No neovim colorscheme found for '$palette'.

To add one:
  1. cp $APPS_DIR/TEMPLATE-neovim.lua $APPS_DIR/$palette/neovim.lua
  2. Edit the file - the template has instructions for finding the right plugin
  3. Run: theme-set --neovim $palette
EOF
}

set_neovim() {
    local palette="$1"
    local nvim_src="$APPS_DIR/$palette/neovim.lua"

    if [[ ! -f "$nvim_src" ]]; then
        neovim_guide "$palette"
        exit 1
    fi

    mkdir -p "$(dirname "$NVIM_COLORSCHEME")"
    cp "$nvim_src" "$NVIM_COLORSCHEME"
    echo "Neovim colorscheme updated for '$palette'."
    echo "Restart neovim to pick up the new colorscheme."
}

set_wallpaper() {
    local palette_file="$1"
    local wallpaper=""

    # Extract optional wallpaper field from palette
    while IFS= read -r line; do
        if [[ "$line" =~ ^[[:space:]]*wallpaper[[:space:]]*=[[:space:]]*\"([^\"]+)\" ]]; then
            wallpaper="${BASH_REMATCH[1]}"
            break
        fi
    done < "$palette_file"

    [[ -z "$wallpaper" ]] && return 0

    local expanded="${wallpaper/#\~/$HOME}"

    if [[ ! -f "$expanded" ]]; then
        echo "warning: wallpaper not found: $wallpaper" >&2
        return 0
    fi

    # Apply instantly via hyprctl IPC (requires hyprpaper > 0.8.3)
    if command -v hyprctl &>/dev/null; then
        local monitors
        monitors="$(hyprctl monitors -j 2>/dev/null | jq -r '.[].name' 2>/dev/null)"
        while IFS= read -r monitor; do
            [[ -z "$monitor" ]] && continue
            hyprctl hyprpaper wallpaper "$monitor, $expanded" 2>/dev/null
        done <<< "$monitors"
    fi

    # Persist to hyprpaper.conf for next reboot
    local conf="$HOME/.config/hypr/hyprpaper.conf"
    if [[ -f "$conf" ]]; then
        sed -i "s|^\([[:space:]]*path = \).*|\1${wallpaper}|" "$conf"
    fi

    echo "Wallpaper: $wallpaper"
}

list_palettes() {
    echo "Available palettes:"
    for f in "$PALETTES_DIR"/*.toml; do
        [[ -f "$f" ]] || continue
        local name
        name="$(basename "$f" .toml)"
        if [[ -f "$COLORS_FILE" ]] && diff -q "$f" "$COLORS_FILE" &>/dev/null; then
            echo "  $name (active)"
        else
            echo "  $name"
        fi
    done
}

main() {
    if [[ $# -eq 0 ]]; then
        list_palettes
        exit 0
    fi

    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --neovim)
            if [[ -z "${2:-}" ]]; then
                echo "error: --neovim requires a palette name" >&2
                echo "Run 'theme-set --help' for usage." >&2
                exit 1
            fi
            set_neovim "$2"
            exit 0
            ;;
        -*)
            echo "error: unknown option '$1'" >&2
            echo "Run 'theme-set --help' for usage." >&2
            exit 1
            ;;
    esac

    local palette="$1"
    local palette_file="$PALETTES_DIR/${palette}.toml"

    if [[ ! -f "$palette_file" ]]; then
        echo "error: palette '$palette' not found" >&2
        echo "" >&2
        list_palettes >&2
        exit 1
    fi

    # Copy palette to colors.toml
    cp "$palette_file" "$COLORS_FILE"
    echo "Palette: $palette"

    # Run theme-apply
    "$THEME_APPLY"

    # Pattern E: copy neovim metadata if available
    local nvim_src="$APPS_DIR/$palette/neovim.lua"
    if [[ -f "$nvim_src" ]]; then
        mkdir -p "$(dirname "$NVIM_COLORSCHEME")"
        cp "$nvim_src" "$NVIM_COLORSCHEME"
        echo "Neovim colorscheme updated."
    fi

    # Reload apps that need explicit signals
    killall -SIGUSR2 ghostty 2>/dev/null || true
    killall -SIGUSR2 waybar 2>/dev/null || true
    makoctl reload 2>/dev/null || true

    # Set wallpaper if palette defines one
    set_wallpaper "$palette_file"

    echo ""
    echo "Restart yazi, lazygit, btop, and neovim to pick up new theme."
}

main "$@"
