{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "type": "file",
    "source": "~/.config/fastfetch/logo.txt",
    "color": {
      "1": "{gradient1}",
      "2": "{gradient2}",
      "3": "{gradient3}",
      "4": "{gradient4}",
      "5": "{gradient5}",
      "6": "{gradient6}",
      "7": "{gradient7}",
      "8": "{gradient8}",
      "9": "{gradient9}"
    },
    "padding": {
      "top": 0,
      "left": 0,
      "right": 4
    }
  },
  "display": {
    "color": {
      "keys": "{accent}",
      "title": "{accent}",
      "output": "{magenta}",
      "separator": "{accent}"
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "editor",
    "display",
    "wm",
    "terminal",
    "terminalfont",
    "cpu",
    "gpu",
    "memory",
    "disk",
    "localip",
    "battery",
    "poweradapter",
    "break",
    "colors"
  ]
}
