# hyprtoolkit theme - controls the appearance of hyprlauncher

# Colors
background = rgba({background.strip}e6)
base = rgba({color0.strip}e6)
text = rgba({foreground.strip}ff)
alternate_base = rgba({color8.strip}e6)
bright_text = rgba({foreground.strip}ff)
accent = rgba({magenta.strip}ff)
accent_secondary = rgba({cyan.strip}ff)

# Typography
font_family = JetBrainsMono Nerd Font
font_size = 14
small_font_size = 12
h1_size = 22
h2_size = 18
h3_size = 16

# Rounding
rounding_large = 12
rounding_small = 8
